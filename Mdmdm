2. ParseFileAsync 전체 교체


private async Task ParseFileAsync(string file)
{
    using (var fs = new FileStream(file, FileMode.Open, FileAccess.Read, FileShare.ReadWrite))
    using (var sr = new StreamReader(fs, Encoding.UTF8, true, 1024 * 64))
    {
        string line;
        long idx = 0;
        var source = Path.GetFileName(file);

        while ((line = await sr.ReadLineAsync()) != null)
        {
            var m = headRx.Match(line);
            if (!m.Success)
            {
                idx++;
                continue;
            }

            DateTime ts;
            if (!DateTime.TryParse(m.Groups["dt"].Value, out ts))
            {
                idx++;
                continue;
            }

            string level = m.Groups["level"].Value;
            string rest = m.Groups["rest"].Value;

            var tokens = new List<string>();
            string tmp = rest;
            int guard = 0;

            while (guard < 10)
            {
                var bm = bracketRx.Match(tmp);
                if (!bm.Success)
                    break;

                tokens.Add((bm.Groups["tok"].Value ?? "").Trim());
                tmp = tmp.Substring(bm.Length).TrimStart();

                guard++;
            }

            string device = GetDeviceFromFileName(file);
            string varName = PickVarFromTokens(tokens);

            if (string.IsNullOrWhiteSpace(varName))
                varName = device ?? "GLOBAL";

            var kind = DetectKind(tmp);

            // Fail - 사유처럼 뒤쪽에 붙은 케이스 보조 감지
            if (kind == ActionKind.Other)
                kind = DetectKind(rest);

            bool isOne =
                (kind == ActionKind.Start) &&
                !varName.StartsWith("BR_", StringComparison.OrdinalIgnoreCase);

            lock (locker)
            {
                rows.Add(new LogRow
                {
                    Timestamp = ts,
                    Level = level,
                    Device = device,
                    Var = varName,
                    SourceFile = source,
                    LineIndex = idx,
                    IsOneLiner = isOne,
                    Kind = kind,
                    Var_ = rest
                });
            }

            idx++;
        }
    }
}




3. GetVarFromHeader 전체 교체


private string GetVarFromHeader(string sourceFile, string rest)
{
    var tokens = new List<string>();
    string tmp = rest ?? "";
    int guard = 0;

    while (guard < 10)
    {
        var m = bracketRx.Match(tmp);
        if (!m.Success)
            break;

        tokens.Add((m.Groups["tok"].Value ?? "").Trim());
        tmp = tmp.Substring(m.Length).TrimStart();

        guard++;
    }

    string varName = PickVarFromTokens(tokens);

    if (!string.IsNullOrWhiteSpace(varName))
        return varName;

    var device = GetDeviceFromFileName(sourceFile);
    return device ?? "GLOBAL";
}




4. DetectKind 전체 교체


private ActionKind DetectKind(string text)
{
    if (string.IsNullOrWhiteSpace(text))
        return ActionKind.Other;

    text = text.Trim();

    // Fail은 사유와 같이 붙어오므로 전체 검색 허용
    if (Regex.IsMatch(text, @"\bFail\b", RegexOptions.IgnoreCase))
        return ActionKind.Fail;

    if (Regex.IsMatch(text, @"ACK\s*=\s*NG", RegexOptions.IgnoreCase))
        return ActionKind.Fail;

    // Start/Success/End는 오탐 방지 위해 앞쪽 기준만 허용
    // JOB_START, Request Start Time 같은 문자열 오탐 방지
    if (text.StartsWith("Success", StringComparison.OrdinalIgnoreCase))
        return ActionKind.Success;

    if (text.StartsWith("End", StringComparison.OrdinalIgnoreCase))
        return ActionKind.End;

    if (text.StartsWith("Start", StringComparison.OrdinalIgnoreCase))
        return ActionKind.Start;

    return ActionKind.Other;
}




5. BuildMergedQueue 전체 교체


private List<CombinedRow> BuildMergedQueue(IEnumerable<LogRow> ordered)
{
    var result = new List<CombinedRow>();
    var queues = new Dictionary<string, Queue<CombinedRow>>(StringComparer.OrdinalIgnoreCase);

    foreach (var r in ordered)
    {
        if (string.IsNullOrEmpty(r.Var) || !r.Var.StartsWith("BR_", StringComparison.OrdinalIgnoreCase))
            continue;

        Queue<CombinedRow> q;
        if (!queues.TryGetValue(r.Var, out q))
        {
            q = new Queue<CombinedRow>();
            queues[r.Var] = q;
        }

        if (r.Kind == ActionKind.Start)
        {
            q.Enqueue(new CombinedRow
            {
                Var = r.Var,
                StartTs = r.Timestamp,
                Status = "Unknown",
                SourceFile = r.SourceFile,
                StartIdx = (int)r.LineIndex,
                EndIdx = -1,
                SuccessIdx = -1,
                MLot = ""
            });
        }
        else if (r.Kind == ActionKind.Success)
        {
            if (q.Count > 0)
            {
                var cur = q.Peek();

                cur.SuccessTs = r.Timestamp;
                cur.SuccessIdx = (int)r.LineIndex;
                cur.EndTs = r.Timestamp;
                cur.EndIdx = (int)r.LineIndex;
                cur.Status = "Success";
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

                FillLotByIndex(cur);

                // 기존 정상 패턴 보존:
                // Start Start Success End Success End
                // Success에서 바로 Add 하지 않고 End에서 닫음
            }
            else
            {
                // Start 없이 Success만 있는 로그도 사실 그대로 표시
                var row = new CombinedRow
                {
                    Var = r.Var,
                    StartTs = r.Timestamp,
                    SuccessTs = r.Timestamp,
                    EndTs = r.Timestamp,
                    Status = "Success",
                    SourceFile = r.SourceFile,
                    StartIdx = (int)r.LineIndex,
                    EndIdx = (int)r.LineIndex,
                    SuccessIdx = (int)r.LineIndex,
                    DurationSeconds = 0,
                    MLot = ""
                };

                FillLotByIndex(row);
                result.Add(row);
            }
        }
        else if (r.Kind == ActionKind.End)
        {
            if (q.Count > 0)
            {
                var cur = q.Dequeue();

                cur.EndTs = r.Timestamp;
                cur.EndIdx = (int)r.LineIndex;
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

                if (cur.Status == "Success")
                {
                    // SuccessIdx는 Success 라인 유지
                    FillLotByIndex(cur);
                    result.Add(cur);
                }
                else
                {
                    // Start + End만 있는 경우
                    // 작업 흔적은 있으므로 Unknown 표시
                    cur.Status = "Unknown";
                    cur.SuccessTs = r.Timestamp;
                    cur.SuccessIdx = (int)r.LineIndex; // JSON/LOT 조회 기준

                    FillLotByIndex(cur);
                    result.Add(cur);
                }
            }
            else
            {
                // End 단독도 사실 그대로 표시
                var row = new CombinedRow
                {
                    Var = r.Var,
                    StartTs = r.Timestamp,
                    SuccessTs = r.Timestamp,
                    EndTs = r.Timestamp,
                    Status = "Unknown",
                    SourceFile = r.SourceFile,
                    StartIdx = (int)r.LineIndex,
                    EndIdx = (int)r.LineIndex,
                    SuccessIdx = (int)r.LineIndex,
                    DurationSeconds = 0,
                    MLot = ""
                };

                FillLotByIndex(row);
                result.Add(row);
            }
        }
        else if (r.Kind == ActionKind.Fail)
        {
            if (q.Count > 0)
            {
                var cur = q.Dequeue();

                cur.SuccessTs = r.Timestamp;
                cur.SuccessIdx = (int)r.LineIndex; // JSON/LOT 조회 기준
                cur.EndTs = r.Timestamp;
                cur.EndIdx = (int)r.LineIndex;
                cur.Status = "NG";
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

                FillLotByIndex(cur);
                result.Add(cur);
            }
            else
            {
                // Fail 단독도 사실 그대로 표시
                var row = new CombinedRow
                {
                    Var = r.Var,
                    StartTs = r.Timestamp,
                    SuccessTs = r.Timestamp,
                    EndTs = r.Timestamp,
                    Status = "NG",
                    SourceFile = r.SourceFile,
                    StartIdx = (int)r.LineIndex,
                    EndIdx = (int)r.LineIndex,
                    SuccessIdx = (int)r.LineIndex,
                    DurationSeconds = 0,
                    MLot = ""
                };

                FillLotByIndex(row);
                result.Add(row);
            }
        }
        else
        {
            // [BR_...] 단독 로그
            if (q.Count > 0)
            {
                // 열린 Start의 상세 범위만 확장
                var cur = q.Peek();

                cur.EndTs = r.Timestamp;
                cur.EndIdx = (int)r.LineIndex;
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));
            }
            else
            {
                // 단독 BR 로그도 사실 그대로 Unknown 표시
                var row = new CombinedRow
                {
                    Var = r.Var,
                    StartTs = r.Timestamp,
                    SuccessTs = r.Timestamp,
                    EndTs = r.Timestamp,
                    Status = "Unknown",
                    SourceFile = r.SourceFile,
                    StartIdx = (int)r.LineIndex,
                    EndIdx = (int)r.LineIndex,
                    SuccessIdx = (int)r.LineIndex,
                    DurationSeconds = 0,
                    MLot = ""
                };

                FillLotByIndex(row);
                result.Add(row);
            }
        }
    }

    // 남은 Start도 작업 흔적이므로 Unknown 표시
    foreach (var kv in queues)
    {
        var q = kv.Value;

        while (q.Count > 0)
        {
            var cur = q.Dequeue();

            if (!cur.EndTs.HasValue)
            {
                cur.EndTs = cur.StartTs;
                cur.EndIdx = cur.StartIdx;
            }

            cur.SuccessTs = cur.EndTs;
            cur.SuccessIdx = cur.EndIdx >= 0 ? cur.EndIdx : cur.StartIdx;
            cur.Status = cur.Status == "Success" ? "Success" : "Unknown";
            cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

            FillLotByIndex(cur);
            result.Add(cur);
        }
    }

    // 중복 제거 금지
    // 실제 로그 기준으로 그대로 보여줌
    return result.OrderBy(x => x.StartTs).ThenBy(x => x.StartIdx).ToList();
}




6. 헬퍼 메서드 추가


private string PickVarFromTokens(List<string> tokens)
{
    if (tokens == null || tokens.Count == 0)
        return null;

    var br = tokens.FirstOrDefault(t =>
        !string.IsNullOrWhiteSpace(t) &&
        t.Trim().StartsWith("BR_", StringComparison.OrdinalIgnoreCase));

    if (!string.IsNullOrWhiteSpace(br))
        return br.Trim();

    var valid = tokens
        .Select(t => (t ?? "").Trim())
        .Where(t => !string.IsNullOrWhiteSpace(t))
        .Where(t => !t.StartsWith("STEP_", StringComparison.OrdinalIgnoreCase))
        .ToList();

    if (valid.Count > 0)
        return valid.Last();

    return null;
}

private string GetDeviceFromFileName(string file)
{
    var n = Path.GetFileNameWithoutExtension(file);
    var cut = n.LastIndexOf('_');

    return cut > 0 ? n.Substring(0, cut) : n;
}

private void FillLotByIndex(CombinedRow row)
{
    if (row == null)
        return;

    if (!string.IsNullOrEmpty(row.MLot))
        return;

    if (row.SuccessIdx < 0)
        return;

    if (kvIndexByFile.TryGetValue(row.SourceFile, out var fileMap) &&
        fileMap.TryGetValue(row.SuccessIdx, out var pairs))
    {
        row.MLot = PickLotFromPairs(row.Var, pairs);
    }
}




7. GridMerged_RowPrePaint는 이 상태로


private void GridMerged_RowPrePaint(object sender, DataGridViewRowPrePaintEventArgs e)
{
    if (e.RowIndex < 0 || e.RowIndex >= gridMerged.Rows.Count)
        return;

    if (gridMerged.Rows[e.RowIndex].IsNewRow)
        return;

    var row = gridMerged.Rows[e.RowIndex].DataBoundItem as CombinedRow;
    if (row == null)
        return;

    var th = (double)numThreshold.Value;

    if ((row.DurationSeconds.HasValue && row.DurationSeconds.Value >= th) ||
        row.Status == "NG" ||
        row.Status == "Unknown")
    {
        gridMerged.Rows[e.RowIndex].DefaultCellStyle.BackColor = Color.FromArgb(255, 220, 220);
    }
    else
    {
        gridMerged.Rows[e.RowIndex].DefaultCellStyle.BackColor = Color.White;
    }
}




