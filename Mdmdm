아래 기준으로 다시 잡습니다.


Start → 큐에 추가
Success → 큐 맨 앞 건을 Success 상태로 표시만 함
End → 큐 맨 앞 건을 종료
Start가 새로 들어왔는데 이전 큐 맨 앞이 Success 상태면 → 이전 건을 Success로 종료
Fail → 큐 맨 앞 건을 NG로 종료
NG는 Fail이 있을 때만 부여



즉, Start + Success 후 End가 안 오고 다음 Start가 오면 이전 건은 Success로 닫습니다.


BuildMergedQueue() 전체 교체


private List<CombinedRow> BuildMergedQueue(IEnumerable<LogRow> ordered)
{
    var result = new List<CombinedRow>();
    var queues = new Dictionary<string, Queue<CombinedRow>>(StringComparer.OrdinalIgnoreCase);

    foreach (var r in ordered)
    {
        if (string.IsNullOrEmpty(r.Var) || !r.Var.StartsWith("BR_", StringComparison.OrdinalIgnoreCase))
            continue;

        Queue<CombinedRow> q;
        if (!queues.TryGetValue(r.Var, out q))
        {
            q = new Queue<CombinedRow>();
            queues[r.Var] = q;
        }

        if (r.Kind == ActionKind.Start)
        {
            // 핵심:
            // 이전 건이 Success까지 찍혔는데 End가 안 왔다면,
            // 새 Start 시점에서 이전 건을 Success로 확정 종료한다.
            while (q.Count > 0 && q.Peek().Status == "Success")
            {
                var done = q.Dequeue();

                if (!done.EndTs.HasValue)
                {
                    done.EndTs = done.SuccessTs ?? done.StartTs;
                    done.EndIdx = done.SuccessIdx >= 0 ? done.SuccessIdx : done.StartIdx;
                }

                done.Status = "Success";
                done.DurationSeconds = Math.Max(0, Math.Round((done.EndTs.Value - done.StartTs).TotalSeconds, 3));

                FillLotByIndex(done);
                result.Add(done);
            }

            q.Enqueue(new CombinedRow
            {
                Var = r.Var,
                StartTs = r.Timestamp,
                Status = "Unknown",
                SourceFile = r.SourceFile,
                StartIdx = (int)r.LineIndex,
                EndIdx = -1,
                SuccessIdx = -1,
                MLot = ""
            });
        }
        else if (r.Kind == ActionKind.Success)
        {
            if (q.Count > 0)
            {
                // FIFO 기준: 가장 먼저 열린 Start에 Success 매칭
                var cur = q.Peek();

                cur.SuccessTs = r.Timestamp;
                cur.SuccessIdx = (int)r.LineIndex;
                cur.EndTs = r.Timestamp;
                cur.EndIdx = (int)r.LineIndex;
                cur.Status = "Success";
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

                FillLotByIndex(cur);

                // 여기서 바로 result.Add 하지 않음.
                // End가 오면 End에서 닫고,
                // End가 안 오고 다음 Start가 오면 Start에서 Success로 닫음.
            }
            else
            {
                // Start 없이 Success만 있는 경우도 실제 로그이므로 표시
                var row = new CombinedRow
                {
                    Var = r.Var,
                    StartTs = r.Timestamp,
                    SuccessTs = r.Timestamp,
                    EndTs = r.Timestamp,
                    Status = "Success",
                    SourceFile = r.SourceFile,
                    StartIdx = (int)r.LineIndex,
                    EndIdx = (int)r.LineIndex,
                    SuccessIdx = (int)r.LineIndex,
                    DurationSeconds = 0,
                    MLot = ""
                };

                FillLotByIndex(row);
                result.Add(row);
            }
        }
        else if (r.Kind == ActionKind.End)
        {
            if (q.Count > 0)
            {
                var cur = q.Dequeue();

                cur.EndTs = r.Timestamp;
                cur.EndIdx = (int)r.LineIndex;
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

                if (cur.Status == "Success")
                {
                    // SuccessIdx는 Success 라인 유지
                    FillLotByIndex(cur);
                    result.Add(cur);
                }
                else
                {
                    // Start + End만 있는 경우
                    // 성공/실패 판단 불가 → Unknown
                    cur.Status = "Unknown";
                    cur.SuccessTs = r.Timestamp;
                    cur.SuccessIdx = (int)r.LineIndex; // JSON/LOT 기준은 End 라인

                    FillLotByIndex(cur);
                    result.Add(cur);
                }
            }
            else
            {
                // End 단독
                var row = new CombinedRow
                {
                    Var = r.Var,
                    StartTs = r.Timestamp,
                    SuccessTs = r.Timestamp,
                    EndTs = r.Timestamp,
                    Status = "Unknown",
                    SourceFile = r.SourceFile,
                    StartIdx = (int)r.LineIndex,
                    EndIdx = (int)r.LineIndex,
                    SuccessIdx = (int)r.LineIndex,
                    DurationSeconds = 0,
                    MLot = ""
                };

                FillLotByIndex(row);
                result.Add(row);
            }
        }
        else if (r.Kind == ActionKind.Fail)
        {
            if (q.Count > 0)
            {
                // Fail이 있을 때만 NG
                var cur = q.Dequeue();

                cur.SuccessTs = r.Timestamp;
                cur.SuccessIdx = (int)r.LineIndex;
                cur.EndTs = r.Timestamp;
                cur.EndIdx = (int)r.LineIndex;
                cur.Status = "NG";
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

                FillLotByIndex(cur);
                result.Add(cur);
            }
            else
            {
                // Fail 단독
                var row = new CombinedRow
                {
                    Var = r.Var,
                    StartTs = r.Timestamp,
                    SuccessTs = r.Timestamp,
                    EndTs = r.Timestamp,
                    Status = "NG",
                    SourceFile = r.SourceFile,
                    StartIdx = (int)r.LineIndex,
                    EndIdx = (int)r.LineIndex,
                    SuccessIdx = (int)r.LineIndex,
                    DurationSeconds = 0,
                    MLot = ""
                };

                FillLotByIndex(row);
                result.Add(row);
            }
        }
        else
        {
            // [BR_...] 단독 로그
            if (q.Count > 0)
            {
                // 열린 Start의 상세 범위만 확장
                var cur = q.Peek();

                cur.EndTs = r.Timestamp;
                cur.EndIdx = (int)r.LineIndex;
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));
            }
            else
            {
                // 단독 BR 로그도 표시
                var row = new CombinedRow
                {
                    Var = r.Var,
                    StartTs = r.Timestamp,
                    SuccessTs = r.Timestamp,
                    EndTs = r.Timestamp,
                    Status = "Unknown",
                    SourceFile = r.SourceFile,
                    StartIdx = (int)r.LineIndex,
                    EndIdx = (int)r.LineIndex,
                    SuccessIdx = (int)r.LineIndex,
                    DurationSeconds = 0,
                    MLot = ""
                };

                FillLotByIndex(row);
                result.Add(row);
            }
        }
    }

    // 파일 끝까지 남은 큐 처리
    foreach (var kv in queues)
    {
        var q = kv.Value;

        while (q.Count > 0)
        {
            var cur = q.Dequeue();

            if (cur.Status == "Success")
            {
                // Start + Success까지만 있고 End가 없어도 Success 유지
                if (!cur.EndTs.HasValue)
                {
                    cur.EndTs = cur.SuccessTs ?? cur.StartTs;
                    cur.EndIdx = cur.SuccessIdx >= 0 ? cur.SuccessIdx : cur.StartIdx;
                }

                cur.Status = "Success";
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

                FillLotByIndex(cur);
                result.Add(cur);
            }
            else
            {
                // Success도 Fail도 없는 Start 잔여 건은 Unknown
                if (!cur.EndTs.HasValue)
                {
                    cur.EndTs = cur.StartTs;
                    cur.EndIdx = cur.StartIdx;
                }

                cur.SuccessTs = cur.EndTs;
                cur.SuccessIdx = cur.EndIdx >= 0 ? cur.EndIdx : cur.StartIdx;
                cur.Status = "Unknown";
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

                FillLotByIndex(cur);
                result.Add(cur);
            }
        }
    }

    return result.OrderBy(x => x.StartTs).ThenBy(x => x.StartIdx).ToList();
}



FillLotByIndex() 없으면 추가


private void FillLotByIndex(CombinedRow row)
{
    if (row == null)
        return;

    if (!string.IsNullOrEmpty(row.MLot))
        return;

    if (row.SuccessIdx < 0)
        return;

    if (kvIndexByFile.TryGetValue(row.SourceFile, out var fileMap) &&
        fileMap.TryGetValue(row.SuccessIdx, out var pairs))
    {
        row.MLot = PickLotFromPairs(row.Var, pairs);
    }
}



처리 결과 기준


Start → Success → Start
= 첫 번째 건 Success로 종료 후 새 Start 시작

Start → Success → End
= Success

Start → End
= Unknown

Start → Fail
= NG

Fail 단독
= NG

Success 단독
= Success

End 단독
= Unknown



중요한 점은 이겁니다.


NG는 Fail이 있을 때만 부여
Start + Success는 End가 없어도 Success 유지
Start + Success 후 다음 Start가 오면 이전 건은 Success로 종료



