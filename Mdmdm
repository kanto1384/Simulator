3) ButtonAdd_Click 수정


추가는 그리드만 갱신하면 충분하다고 했으니 이렇게 가면 됩니다.


수정 후


private void ButtonAdd_Click(object? sender, EventArgs e)
{
    if (selectedArrayForAdd == null)
        return;

    switch (selectedAddTemplate)
    {
        case AddTemplateType.DevicesObject:
            selectedArrayForAdd.Add(CreateDevicesTemplate());
            break;

        case AddTemplateType.InfoString:
            selectedArrayForAdd.Add("");
            break;

        case AddTemplateType.DefaultKeyValueObject:
            selectedArrayForAdd.Add(CreateDefaultKeyValueTemplate());
            break;
    }

    RefreshGridForSelectedArray();
}




4) 그리드만 갱신하는 함수


이건 Add/Delete 공용으로 씁니다.


private void RefreshGridForSelectedArray()
{
    if (selectedArrayForAdd == null)
        return;

    var table = CreateDataTableForToken(selectedArrayForAdd);
    dataGridView.DataSource = table;
    dataGridView.Tag = selectedArrayForAdd;
}




