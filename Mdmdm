✅ 4. TreeView 선택 시 Add 활성화 로직


private void TreeView_AfterSelect(object? sender, TreeViewEventArgs e)
{
    // 기존 그리드 바인딩 코드...

    UpdateAddButtonState(e.Node);
}

private void UpdateAddButtonState(TreeNode? node)
{
    selectedArrayForAdd = null;
    selectedAddTemplate = AddTemplateType.None;
    buttonAdd.Enabled = false;

    if (node?.Tag is not JArray arr)
        return;

    var template = ResolveAddTemplate(arr);
    if (template == AddTemplateType.None)
        return;

    selectedArrayForAdd = arr;
    selectedAddTemplate = template;
    buttonAdd.Enabled = true;
}




✅ 5. Path 기준 템플릿 분기


private AddTemplateType ResolveAddTemplate(JArray arr)
{
    var path = arr.Path ?? string.Empty;

    // devices 배열
    if (path == "devices")
        return AddTemplateType.DevicesObject;

    // devices 내부 Info 배열
    if (path.EndsWith(".Info", StringComparison.OrdinalIgnoreCase))
        return AddTemplateType.InfoString;

    // 그 외 배열
    return AddTemplateType.DefaultKeyValueObject;
}




✅ 6. Add 버튼 클릭 로직


private void ButtonAdd_Click(object? sender, EventArgs e)
{
    if (selectedArrayForAdd == null)
        return;

    switch (selectedAddTemplate)
    {
        case AddTemplateType.DevicesObject:
            selectedArrayForAdd.Add(CreateDevicesTemplate());
            break;

        case AddTemplateType.InfoString:
            selectedArrayForAdd.Add("");
            break;

        case AddTemplateType.DefaultKeyValueObject:
            selectedArrayForAdd.Add(CreateDefaultKeyValueTemplate());
            break;
    }

    // 현재 배열만 다시 선택해서 가볍게 갱신
    RebuildTreeAndReselect(selectedArrayForAdd);
}




✅ 7. 템플릿 생성 메서드


private JObject CreateDevicesTemplate()
{
    return new JObject
    {
        ["Ip"] = "",
        ["Id"] = "",
        ["Info"] = new JArray(),
        ["Password"] = "",
        ["Note"] = ""
    };
}

private JObject CreateDefaultKeyValueTemplate()
{
    return new JObject
    {
        ["Key"] = "",
        ["Value"] = ""
    };
}




