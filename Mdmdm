맞습니다. 내가 판단해서 SuccessIdx = -1로 죽이면 안 됩니다.

표시되는 모든 Row는 JSON/LOT 기준 인덱스를 반드시 가져야 합니다.


아래 코드로 가세요.


기준:


Success → SuccessIdx = Success 라인
NG      → SuccessIdx = Fail 라인
Unknown → SuccessIdx = End 라인, 없으면 Start 라인



gridMerged_CellFormatting이 SuccessIdx로 kvIndexByFile을 조회하는 구조라서, 모든 표시 Row에 SuccessIdx를 넣어야 JSON 동적 컬럼이 살아납니다. 기존 소스도 SuccessIdx를 기준으로 동적 컬럼 값을 가져오는 구조입니다. 


1. BuildMergedQueue() 전체 교체


private List<CombinedRow> BuildMergedQueue(IEnumerable<LogRow> ordered)
{
    var result = new List<CombinedRow>();
    var queues = new Dictionary<string, Queue<CombinedRow>>(StringComparer.OrdinalIgnoreCase);

    foreach (var r in ordered)
    {
        if (string.IsNullOrEmpty(r.Var) || !r.Var.StartsWith("BR_", StringComparison.OrdinalIgnoreCase))
            continue;

        Queue<CombinedRow> q;
        if (!queues.TryGetValue(r.Var, out q))
        {
            q = new Queue<CombinedRow>();
            queues[r.Var] = q;
        }

        if (r.Kind == ActionKind.Start)
        {
            q.Enqueue(new CombinedRow
            {
                Var = r.Var,
                StartTs = r.Timestamp,
                Status = "Unknown",
                SourceFile = r.SourceFile,
                StartIdx = (int)r.LineIndex,
                EndIdx = -1,
                SuccessIdx = -1,
                MLot = ""
            });
        }
        else if (r.Kind == ActionKind.Success)
        {
            if (q.Count == 0)
                continue;

            var cur = q.Peek();

            cur.SuccessTs = r.Timestamp;
            cur.SuccessIdx = (int)r.LineIndex;   // JSON/LOT 기준
            cur.EndTs = r.Timestamp;
            cur.EndIdx = (int)r.LineIndex;
            cur.Status = "Success";
            cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

            FillLotByIndex(cur);

            // 기존 정상 패턴:
            // Start Start Success End Success End
            // 때문에 Success에서 바로 Add 하지 않고 End에서 닫음
        }
        else if (r.Kind == ActionKind.End)
        {
            if (q.Count == 0)
                continue;

            var cur = q.Dequeue();

            cur.EndTs = r.Timestamp;
            cur.EndIdx = (int)r.LineIndex;
            cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

            if (cur.Status == "Success")
            {
                // SuccessIdx는 Success 라인 유지
                FillLotByIndex(cur);
                result.Add(cur);
            }
            else
            {
                // Start + End만 있는 경우도 작업 흔적이므로 Unknown 표시
                // JSON/LOT도 보여야 하므로 End 라인을 기준으로 넣음
                cur.SuccessTs = r.Timestamp;
                cur.SuccessIdx = (int)r.LineIndex;   // JSON/LOT 기준
                cur.Status = "Unknown";

                FillLotByIndex(cur);
                result.Add(cur);
            }
        }
        else if (r.Kind == ActionKind.Fail)
        {
            if (q.Count > 0)
            {
                var cur = q.Dequeue();

                cur.SuccessTs = r.Timestamp;
                cur.SuccessIdx = (int)r.LineIndex;   // JSON/LOT 기준
                cur.EndTs = r.Timestamp;
                cur.EndIdx = (int)r.LineIndex;
                cur.Status = "NG";
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

                FillLotByIndex(cur);
                result.Add(cur);
            }
            else
            {
                // Start 없이 Fail만 나온 경우도 NG 표시
                var failRow = new CombinedRow
                {
                    Var = r.Var,
                    StartTs = r.Timestamp,
                    SuccessTs = r.Timestamp,
                    EndTs = r.Timestamp,
                    Status = "NG",
                    SourceFile = r.SourceFile,
                    StartIdx = (int)r.LineIndex,
                    EndIdx = (int)r.LineIndex,
                    SuccessIdx = (int)r.LineIndex,   // JSON/LOT 기준
                    DurationSeconds = 0,
                    MLot = ""
                };

                FillLotByIndex(failRow);
                result.Add(failRow);
            }
        }
        else
        {
            // Other는 판정에는 사용하지 않음
            continue;
        }
    }

    // 남은 Start도 Unknown으로 표시
    foreach (var kv in queues)
    {
        var q = kv.Value;

        while (q.Count > 0)
        {
            var cur = q.Dequeue();

            if (!cur.EndTs.HasValue)
            {
                cur.EndTs = cur.StartTs;
                cur.EndIdx = cur.StartIdx;
            }

            cur.SuccessTs = cur.EndTs;
            cur.SuccessIdx = cur.EndIdx >= 0 ? cur.EndIdx : cur.StartIdx;   // JSON/LOT 기준
            cur.Status = "Unknown";
            cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

            FillLotByIndex(cur);
            result.Add(cur);
        }
    }

    return result.OrderBy(x => x.StartTs).ToList();
}



2. 헬퍼 메서드 추가


같은 클래스 안에 추가하세요.


private void FillLotByIndex(CombinedRow row)
{
    if (row == null)
        return;

    if (!string.IsNullOrEmpty(row.MLot))
        return;

    if (row.SuccessIdx < 0)
        return;

    if (kvIndexByFile.TryGetValue(row.SourceFile, out var fileMap) &&
        fileMap.TryGetValue(row.SuccessIdx, out var pairs))
    {
        row.MLot = PickLotFromPairs(row.Var, pairs);
    }
}



