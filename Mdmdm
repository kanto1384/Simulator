아래 코드만 반영하세요.

핵심은 Unknown 유지 + JSON 동적 컬럼 유지 + 기존 Start/Success/End 패턴 유지입니다. THICK_NG_SECTION처럼 Start/End/Fail이 섞이는 로그와, THICK_SCAN_AVG처럼 Start/Success/End가 반복되는 로그가 같이 있으니 End=Success로 단정하면 안 됩니다.


1. BuildMergedQueue() 전체 교체


private List<CombinedRow> BuildMergedQueue(IEnumerable<LogRow> ordered)
{
    var result = new List<CombinedRow>();
    var queues = new Dictionary<string, Queue<CombinedRow>>(StringComparer.OrdinalIgnoreCase);

    foreach (var r in ordered)
    {
        if (string.IsNullOrEmpty(r.Var) || !r.Var.StartsWith("BR_", StringComparison.OrdinalIgnoreCase))
            continue;

        Queue<CombinedRow> q;
        if (!queues.TryGetValue(r.Var, out q))
        {
            q = new Queue<CombinedRow>();
            queues[r.Var] = q;
        }

        if (r.Kind == ActionKind.Start)
        {
            q.Enqueue(new CombinedRow
            {
                Var = r.Var,
                StartTs = r.Timestamp,
                Status = "Unknown",
                SourceFile = r.SourceFile,
                StartIdx = (int)r.LineIndex,
                EndIdx = -1,
                SuccessIdx = -1
            });
        }
        else if (r.Kind == ActionKind.Success)
        {
            if (q.Count == 0)
                continue;

            var cur = q.Peek();

            cur.SuccessTs = r.Timestamp;
            cur.SuccessIdx = (int)r.LineIndex;   // JSON 동적 컬럼 기준
            cur.EndTs = r.Timestamp;
            cur.EndIdx = (int)r.LineIndex;
            cur.Status = "Success";
            cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

            FillLotIfPossible(cur);

            // Success만으로는 result.Add 하지 않음.
            // 기존 정상 패턴 Start Start Success End Success End 때문에 End에서 닫음.
        }
        else if (r.Kind == ActionKind.End)
        {
            if (q.Count == 0)
                continue;

            var cur = q.Dequeue();

            cur.EndTs = r.Timestamp;
            cur.EndIdx = (int)r.LineIndex;
            cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

            if (cur.Status == "Success")
            {
                // SuccessIdx는 기존 Success 라인 유지
                FillLotIfPossible(cur);
                result.Add(cur);
            }
            else
            {
                // Start + End만 있는 경우
                // 작업 흔적은 있으므로 Unknown 표시
                // JSON/동적 컬럼 기준으로 End 라인을 넣음
                cur.SuccessTs = r.Timestamp;
                cur.SuccessIdx = (int)r.LineIndex;
                cur.Status = "Unknown";

                FillLotIfPossible(cur);
                result.Add(cur);
            }
        }
        else if (r.Kind == ActionKind.Fail)
        {
            if (q.Count > 0)
            {
                var cur = q.Dequeue();

                cur.SuccessTs = r.Timestamp;
                cur.SuccessIdx = (int)r.LineIndex;   // JSON 동적 컬럼 기준
                cur.EndTs = r.Timestamp;
                cur.EndIdx = (int)r.LineIndex;
                cur.Status = "NG";
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

                FillLotIfPossible(cur);
                result.Add(cur);
            }
            else
            {
                // Start 없이 Fail만 나온 경우도 NG로 표시
                var failRow = new CombinedRow
                {
                    Var = r.Var,
                    StartTs = r.Timestamp,
                    SuccessTs = r.Timestamp,
                    EndTs = r.Timestamp,
                    Status = "NG",
                    SourceFile = r.SourceFile,
                    StartIdx = (int)r.LineIndex,
                    EndIdx = (int)r.LineIndex,
                    SuccessIdx = (int)r.LineIndex,   // JSON 동적 컬럼 기준
                    DurationSeconds = 0
                };

                FillLotIfPossible(failRow);
                result.Add(failRow);
            }
        }
        else
        {
            // Other는 판정에 사용하지 않음
            // [BR_...] 단독 로그로 큐를 건드리면 기존 정상 패턴이 깨질 수 있음
            continue;
        }
    }

    // 남은 Start도 작업 흔적이므로 Unknown으로 표시
    foreach (var kv in queues)
    {
        var q = kv.Value;

        while (q.Count > 0)
        {
            var cur = q.Dequeue();

            if (!cur.EndTs.HasValue)
            {
                cur.EndTs = cur.StartTs;
                cur.EndIdx = cur.StartIdx;
            }

            cur.SuccessTs = cur.EndTs;
            cur.SuccessIdx = cur.EndIdx >= 0 ? cur.EndIdx : cur.StartIdx;   // JSON 동적 컬럼 기준
            cur.Status = "Unknown";
            cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

            FillLotIfPossible(cur);
            result.Add(cur);
        }
    }

    return result.OrderBy(x => x.StartTs).ToList();
}



2. 헬퍼 메서드 추가


같은 클래스 안에 추가하세요.


private void FillLotIfPossible(CombinedRow row)
{
    if (row == null)
        return;

    if (!string.IsNullOrEmpty(row.MLot))
        return;

    if (row.SuccessIdx < 0)
        return;

    if (kvIndexByFile.TryGetValue(row.SourceFile, out var fileMap) &&
        fileMap.TryGetValue(row.SuccessIdx, out var pairs))
    {
        row.MLot = PickLotFromPairs(row.Var, pairs);
    }
}



3. GridMerged_RowPrePaint() 조건 교체


Unknown도 확인 가능하게 색상 처리합니다.


private void GridMerged_RowPrePaint(object sender, DataGridViewRowPrePaintEventArgs e)
{
    if (e.RowIndex < 0 || e.RowIndex >= gridMerged.Rows.Count)
        return;

    if (gridMerged.Rows[e.RowIndex].IsNewRow)
        return;

    var row = gridMerged.Rows[e.RowIndex].DataBoundItem as CombinedRow;
    if (row == null)
        return;

    var th = (double)numThreshold.Value;

    if ((row.DurationSeconds.HasValue && row.DurationSeconds.Value >= th) ||
        row.Status == "NG" ||
        row.Status == "Unknown")
    {
        gridMerged.Rows[e.RowIndex].DefaultCellStyle.BackColor = Color.FromArgb(255, 220, 220);
    }
    else
    {
        gridMerged.Rows[e.RowIndex].DefaultCellStyle.BackColor = Color.White;
    }
}



최종 상태 기준:


Start + Success + End  → Success
Start + End            → Unknown
Start만 남음           → Unknown
Start + Fail           → NG
Fail 단독              → NG
Success 단독           → 무시
End 단독               → 무시



SuccessIdx는 모든 표시 행에 채워지므로 JSON 동적 컬럼도 다시 펼쳐져야 합니다.

