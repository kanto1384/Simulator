아래 코드 기준으로 정리합니다.


기준은 이겁니다.


로그 Row 제거 안 함
결과 Row 임의 중복 제거 안 함
Success / Fail / End / Other / Start 단독도 가능한 한 표시
LOT / JSON 컬럼은 표시 Row의 SuccessIdx 기준으로 조회



네 기존 소스는 동적 컬럼/LOT을 SuccessIdx -> kvIndexByFile 기준으로 펼치는 구조라서, 표시되는 Row에는 반드시 SuccessIdx가 있어야 합니다. 



1. BuildMergedQueue() 전체 교체


private List<CombinedRow> BuildMergedQueue(IEnumerable<LogRow> ordered)
{
    var result = new List<CombinedRow>();
    var queues = new Dictionary<string, Queue<CombinedRow>>(StringComparer.OrdinalIgnoreCase);

    foreach (var r in ordered)
    {
        if (string.IsNullOrEmpty(r.Var) || !r.Var.StartsWith("BR_", StringComparison.OrdinalIgnoreCase))
            continue;

        Queue<CombinedRow> q;
        if (!queues.TryGetValue(r.Var, out q))
        {
            q = new Queue<CombinedRow>();
            queues[r.Var] = q;
        }

        if (r.Kind == ActionKind.Start)
        {
            q.Enqueue(new CombinedRow
            {
                Var = r.Var,
                StartTs = r.Timestamp,
                Status = "Unknown",
                SourceFile = r.SourceFile,
                StartIdx = (int)r.LineIndex,
                EndIdx = -1,
                SuccessIdx = -1,
                MLot = ""
            });
        }
        else if (r.Kind == ActionKind.Success)
        {
            if (q.Count > 0)
            {
                var cur = q.Peek();

                cur.SuccessTs = r.Timestamp;
                cur.SuccessIdx = (int)r.LineIndex;
                cur.EndTs = r.Timestamp;
                cur.EndIdx = (int)r.LineIndex;
                cur.Status = "Success";
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

                FillLotByIndex(cur);

                // 기존 정상 패턴:
                // Start Start Success End Success End
                // 때문에 Success에서는 닫지 않고 End를 기다림
            }
            else
            {
                // Start 없이 Success만 있는 로그도 사실 그대로 표시
                var row = new CombinedRow
                {
                    Var = r.Var,
                    StartTs = r.Timestamp,
                    SuccessTs = r.Timestamp,
                    EndTs = r.Timestamp,
                    Status = "Success",
                    SourceFile = r.SourceFile,
                    StartIdx = (int)r.LineIndex,
                    EndIdx = (int)r.LineIndex,
                    SuccessIdx = (int)r.LineIndex,
                    DurationSeconds = 0,
                    MLot = ""
                };

                FillLotByIndex(row);
                result.Add(row);
            }
        }
        else if (r.Kind == ActionKind.End)
        {
            if (q.Count > 0)
            {
                var cur = q.Dequeue();

                cur.EndTs = r.Timestamp;
                cur.EndIdx = (int)r.LineIndex;
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

                if (cur.Status == "Success")
                {
                    // SuccessIdx는 Success 라인 유지
                    FillLotByIndex(cur);
                    result.Add(cur);
                }
                else
                {
                    // Start + End만 있는 경우
                    cur.Status = "Unknown";
                    cur.SuccessTs = r.Timestamp;
                    cur.SuccessIdx = (int)r.LineIndex; // JSON/LOT 기준: End 라인

                    FillLotByIndex(cur);
                    result.Add(cur);
                }
            }
            else
            {
                // End 단독도 사실 그대로 표시
                var row = new CombinedRow
                {
                    Var = r.Var,
                    StartTs = r.Timestamp,
                    SuccessTs = r.Timestamp,
                    EndTs = r.Timestamp,
                    Status = "Unknown",
                    SourceFile = r.SourceFile,
                    StartIdx = (int)r.LineIndex,
                    EndIdx = (int)r.LineIndex,
                    SuccessIdx = (int)r.LineIndex,
                    DurationSeconds = 0,
                    MLot = ""
                };

                FillLotByIndex(row);
                result.Add(row);
            }
        }
        else if (r.Kind == ActionKind.Fail)
        {
            if (q.Count > 0)
            {
                var cur = q.Dequeue();

                cur.SuccessTs = r.Timestamp;
                cur.SuccessIdx = (int)r.LineIndex; // JSON/LOT 기준: Fail 라인
                cur.EndTs = r.Timestamp;
                cur.EndIdx = (int)r.LineIndex;
                cur.Status = "NG";
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

                FillLotByIndex(cur);
                result.Add(cur);
            }
            else
            {
                // Fail 단독도 표시
                var row = new CombinedRow
                {
                    Var = r.Var,
                    StartTs = r.Timestamp,
                    SuccessTs = r.Timestamp,
                    EndTs = r.Timestamp,
                    Status = "NG",
                    SourceFile = r.SourceFile,
                    StartIdx = (int)r.LineIndex,
                    EndIdx = (int)r.LineIndex,
                    SuccessIdx = (int)r.LineIndex,
                    DurationSeconds = 0,
                    MLot = ""
                };

                FillLotByIndex(row);
                result.Add(row);
            }
        }
        else
        {
            // [BR_...]만 있는 로그도 표시
            if (q.Count > 0)
            {
                var cur = q.Peek();

                // 열린 Start의 상세 범위만 확장
                cur.EndTs = r.Timestamp;
                cur.EndIdx = (int)r.LineIndex;
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));
            }
            else
            {
                // 단독 BR 로그도 Unknown으로 표시
                var row = new CombinedRow
                {
                    Var = r.Var,
                    StartTs = r.Timestamp,
                    SuccessTs = r.Timestamp,
                    EndTs = r.Timestamp,
                    Status = "Unknown",
                    SourceFile = r.SourceFile,
                    StartIdx = (int)r.LineIndex,
                    EndIdx = (int)r.LineIndex,
                    SuccessIdx = (int)r.LineIndex,
                    DurationSeconds = 0,
                    MLot = ""
                };

                FillLotByIndex(row);
                result.Add(row);
            }
        }
    }

    // 남은 Start도 Unknown으로 표시
    foreach (var kv in queues)
    {
        var q = kv.Value;

        while (q.Count > 0)
        {
            var cur = q.Dequeue();

            if (!cur.EndTs.HasValue)
            {
                cur.EndTs = cur.StartTs;
                cur.EndIdx = cur.StartIdx;
            }

            cur.SuccessTs = cur.EndTs;
            cur.SuccessIdx = cur.EndIdx >= 0 ? cur.EndIdx : cur.StartIdx;
            cur.Status = cur.Status == "Success" ? "Success" : "Unknown";
            cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

            FillLotByIndex(cur);
            result.Add(cur);
        }
    }

    // 중복 제거 금지
    // 실제 로그 순서 그대로 보기 위해 StartTs + StartIdx 기준 정렬만 함
    return result.OrderBy(x => x.StartTs).ThenBy(x => x.StartIdx).ToList();
}




2. FillLotByIndex() 추가


private void FillLotByIndex(CombinedRow row)
{
    if (row == null)
        return;

    if (!string.IsNullOrEmpty(row.MLot))
        return;

    if (row.SuccessIdx < 0)
        return;

    if (kvIndexByFile.TryGetValue(row.SourceFile, out var fileMap) &&
        fileMap.TryGetValue(row.SuccessIdx, out var pairs))
    {
        row.MLot = PickLotFromPairs(row.Var, pairs);
    }
}




3. 중요: BuildKVIndexForFile()도 모든 BR 라인을 인덱싱해야 함


LOT/JSON이 안 뜨는 원인이 여기일 가능성이 큽니다. 기존이 Success 블록만 인덱싱하면 Fail, End, Unknown, [BR_] 단독 기준의 SuccessIdx는 못 찾습니다.


BuildKVIndexForFile()을 아래로 교체하세요.


private void BuildKVIndexForFile(string file)
{
    string source = Path.GetFileName(file);

    if (!kvIndexByFile.ContainsKey(source))
        kvIndexByFile[source] = new Dictionary<int, Dictionary<string, Dictionary<int, string>>>();

    if (!lotIndexByFile.ContainsKey(source))
        lotIndexByFile[source] = new Dictionary<int, string>();

    var fileMap = kvIndexByFile[source];
    var lotMap = lotIndexByFile[source];

    string[] lines = File.ReadAllLines(file, Encoding.UTF8);

    for (int i = 0; i < lines.Length; i++)
    {
        string line = lines[i];

        var hm = headRx.Match(line);
        if (!hm.Success)
            continue;

        string rest = hm.Groups["rest"].Value;
        string varName = GetVarFromHeader(source, rest);

        if (string.IsNullOrWhiteSpace(varName) ||
            !varName.StartsWith("BR_", StringComparison.OrdinalIgnoreCase))
        {
            continue;
        }

        var blockLines = new List<string>();

        for (int j = i; j < lines.Length; j++)
        {
            if (j > i && headRx.IsMatch(lines[j]))
                break;

            blockLines.Add(lines[j]);
        }

        var pairs = ExtractKeyValuePairsFromBlock(blockLines);

        // 데이터가 없어도 넣어둠
        // 그래야 SuccessIdx가 Fail/End/Other여도 조회 자체는 가능
        fileMap[i] = pairs;

        string lot = PickLotFromPairs(varName, pairs);
        if (!string.IsNullOrWhiteSpace(lot))
            lotMap[i] = lot;
    }
}




4. ExtractKeyValuePairsFromBlock() 추가


private Dictionary<string, Dictionary<int, string>> ExtractKeyValuePairsFromBlock(List<string> blockLines)
{
    var result = new Dictionary<string, Dictionary<int, string>>(StringComparer.OrdinalIgnoreCase);

    if (blockLines == null || blockLines.Count == 0)
        return result;

    var rx = new Regex(
        @"^\s*\[\s*(?<idx>\d+)\s*:\s*(?<key>[^\]]+)\]\s*[:=]\s*(?<val>.*)$",
        RegexOptions.IgnoreCase);

    foreach (var line in blockLines)
    {
        if (string.IsNullOrWhiteSpace(line))
            continue;

        var m = rx.Match(line);
        if (!m.Success)
            continue;

        int idx;
        if (!int.TryParse(m.Groups["idx"].Value.Trim(), out idx))
            idx = 0;

        string key = (m.Groups["key"].Value ?? "").Trim();
        string val = (m.Groups["val"].Value ?? "").Trim();

        if (string.IsNullOrWhiteSpace(key))
            continue;

        if (!result.TryGetValue(key, out var byIndex))
        {
            byIndex = new Dictionary<int, string>();
            result[key] = byIndex;
        }

        byIndex[idx] = val;
    }

    return result;
}




5. PickLotFromPairs() 교체


private string PickLotFromPairs(string varName, Dictionary<string, Dictionary<int, string>> pairs)
{
    if (pairs == null || pairs.Count == 0)
        return string.Empty;

    var keys = new List<string>();

    if (!string.IsNullOrWhiteSpace(varName) &&
        lotKeyRules != null &&
        lotKeyRules.TryGetValue(varName, out var ruleKeys) &&
        ruleKeys != null)
    {
        keys.AddRange(ruleKeys);
    }

    if (defaultLotKeys != null)
        keys.AddRange(defaultLotKeys);

    keys.AddRange(new[]
    {
        "OUT_LOTID",
        "INPUT_LOTID",
        "INPUT_CSTID",
        "PROD_LOTID",
        "LOTID",
        "LOT_ID",
        "CSTID"
    });

    foreach (var key in keys.Where(k => !string.IsNullOrWhiteSpace(k)).Distinct(StringComparer.OrdinalIgnoreCase))
    {
        if (!pairs.TryGetValue(key, out var byIndex))
            continue;

        var value = byIndex
            .OrderBy(x => x.Key)
            .Select(x => x.Value)
            .FirstOrDefault(v => !string.IsNullOrWhiteSpace(v));

        if (!string.IsNullOrWhiteSpace(value))
            return value.Trim();
    }

    return string.Empty;
}




