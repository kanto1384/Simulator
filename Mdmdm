var tokens = new List<string>();
string tmp = rest;

var bracketRx = new Regex(@"^\s*\[(?<tok>[^\]]*)\]");

int guard = 0;
while (guard < 10)
{
    var bm = bracketRx.Match(tmp);
    if (!bm.Success) break;

    tokens.Add(bm.Groups["tok"].Value.Trim());

    tmp = tmp.Substring(bm.Length).TrimStart();

    guard++;
}

// 로그 레벨 제거
if (tokens.Count > 0 &&
    IsLogLevel(tokens[0]))
{
    tokens.RemoveAt(0);
}

string device = null;
string step = null;
string varName = null;

foreach (var token in tokens)
{
    if (string.IsNullOrWhiteSpace(token))
        continue;

    if (token.StartsWith("STEP_", StringComparison.OrdinalIgnoreCase))
    {
        step = token;
        continue;
    }

    if (token.StartsWith("BR", StringComparison.OrdinalIgnoreCase))
    {
        varName = token;
        continue;
    }

    if (device == null)
    {
        device = token;
    }
}

if (string.IsNullOrEmpty(device))
{
    var n = Path.GetFileNameWithoutExtension(file);
    var cut = n.LastIndexOf('_');
    device = cut > 0 ? n.Substring(0, cut) : n;
}

if (string.IsNullOrEmpty(varName))
{
    varName = device ?? "GLOBAL";
}

var kind = DetectKind(tmp);

string reason = null;

if (kind == "Fail")
{
    int dashIndex = tmp.IndexOf('-');
    if (dashIndex >= 0)
        reason = tmp.Substring(dashIndex + 1).Trim();
}
