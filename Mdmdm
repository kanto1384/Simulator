3. 공유 읽기 메서드 추가


운영 로그 파일이 열려 있어도 읽을 수 있게 합니다.


private string[] ReadAllLinesShared(string file)
{
    var list = new List<string>();

    using (var fs = new FileStream(
        file,
        FileMode.Open,
        FileAccess.Read,
        FileShare.ReadWrite | FileShare.Delete))
    using (var sr = new StreamReader(fs, Encoding.UTF8, true))
    {
        string line;
        while ((line = sr.ReadLine()) != null)
        {
            list.Add(line);
        }
    }

    return list.ToArray();
}




4. 상세 끝 라인 보정 메서드 추가


핵심입니다.

Success, Fail, End 뒤에 붙은 [IN_EQP], [0:LOTID] 같은 데이터 블록까지 포함합니다.


private int GetPhysicalDetailEndIdx(CombinedRow row)
{
    if (row == null)
        return -1;

    int baseEndIdx = Math.Max(row.StartIdx, row.EndIdx);

    if (row.SuccessIdx >= 0)
        baseEndIdx = Math.Max(baseEndIdx, row.SuccessIdx);

    if (baseEndIdx < 0)
        return row.StartIdx;

    if (!sourcePathByFileName.TryGetValue(row.SourceFile, out var file))
        return baseEndIdx;

    if (string.IsNullOrWhiteSpace(file) || !File.Exists(file))
        return baseEndIdx;

    string[] lines;

    try
    {
        lines = ReadAllLinesShared(file);
    }
    catch
    {
        return baseEndIdx;
    }

    if (baseEndIdx >= lines.Length)
        return lines.Length - 1;

    int endIdx = baseEndIdx;

    for (int i = baseEndIdx + 1; i < lines.Length; i++)
    {
        string line = lines[i];

        // 다음 로그 헤더가 나오면 현재 상세 블록 종료
        if (headRx.IsMatch(line))
            break;

        // Success/Fail/End 뒤에 붙는 JSON/KV 본문은 포함
        endIdx = i;
    }

    return endIdx;
}




5. 상세 텍스트 생성 메서드 추가


private string BuildDetailText(CombinedRow row)
{
    if (row == null)
        return string.Empty;

    if (!sourcePathByFileName.TryGetValue(row.SourceFile, out var file))
        return string.Empty;

    if (string.IsNullOrWhiteSpace(file) || !File.Exists(file))
        return string.Empty;

    string[] lines = ReadAllLinesShared(file);

    int startIdx = row.StartIdx;
    int endIdx = GetPhysicalDetailEndIdx(row);

    if (startIdx < 0)
        startIdx = 0;

    if (endIdx < startIdx)
        endIdx = startIdx;

    if (startIdx >= lines.Length)
        return string.Empty;

    if (endIdx >= lines.Length)
        endIdx = lines.Length - 1;

    var sb = new StringBuilder();

    for (int i = startIdx; i <= endIdx; i++)
    {
        sb.AppendLine(lines[i]);
    }

    return sb.ToString();
}




6. 상세창 열 때 기존 상세 생성부 교체


기존에 상세창에서 이런 식으로 하고 있을 겁니다.


var list = rows.Where(r =>
    r.SourceFile == row.SourceFile &&
    r.LineIndex >= row.StartIdx &&
    r.LineIndex <= row.EndIdx)
    .OrderBy(r => r.LineIndex)
    .ToList();



또는 StartIdx ~ EndIdx 기준으로 텍스트를 만들고 있을 겁니다.


그 부분을 아래처럼 바꾸세요.


string detailText = BuildDetailText(row);
txtDetail.Text = detailText;



txtDetail 이름이 다르면, 상세창에서 실제 텍스트박스 이름에 맞춰 넣으면 됩니다.


예:


detailForm.TextBox.Text = BuildDetailText(row);




