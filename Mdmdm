맞습니다. Success는 End가 없어도 사라지면 안 됩니다.

기존 FIFO 의도는 Start → Success만 와도 Success로 살아 있어야 하고, 나중에 End가 오면 같은 Row의 End 시간만 보정되는 구조여야 합니다.


아래 코드로 BuildMergedQueue()만 다시 교체하세요.

BuildKVIndexForFile, PickLotFromPairs, UpdateDynamicColumnsForSearch, gridMerged_CellFormatting은 건드리지 마세요. 기존 동적 컬럼은 SuccessIdx 기준으로 kvIndexByFile을 조회하는 구조라 이쪽을 건드리면 LOT/JSON이 깨집니다. 


private List<CombinedRow> BuildMergedQueue(IEnumerable<LogRow> ordered)
{
    var result = new List<CombinedRow>();
    var added = new HashSet<CombinedRow>(); // 같은 객체 중복 Add 방지
    var queues = new Dictionary<string, Queue<CombinedRow>>(StringComparer.OrdinalIgnoreCase);

    foreach (var r in ordered)
    {
        if (string.IsNullOrEmpty(r.Var) || !r.Var.StartsWith("BR_", StringComparison.OrdinalIgnoreCase))
            continue;

        Queue<CombinedRow> q;
        if (!queues.TryGetValue(r.Var, out q))
        {
            q = new Queue<CombinedRow>();
            queues[r.Var] = q;
        }

        if (r.Kind == ActionKind.Start)
        {
            q.Enqueue(new CombinedRow
            {
                Var = r.Var,
                StartTs = r.Timestamp,
                Status = "Unknown",
                SourceFile = r.SourceFile,
                StartIdx = (int)r.LineIndex,
                EndIdx = -1,
                SuccessIdx = -1,
                MLot = ""
            });
        }
        else if (r.Kind == ActionKind.Success)
        {
            if (q.Count > 0)
            {
                var cur = q.Peek();

                cur.SuccessTs = r.Timestamp;
                cur.SuccessIdx = (int)r.LineIndex; // 기존 JSON/LOT 기준
                cur.EndTs = r.Timestamp;
                cur.EndIdx = (int)r.LineIndex;
                cur.Status = "Success";
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

                FillLotByIndex(cur);

                // 중요:
                // End가 없어도 Success는 화면에 떠야 함.
                // 나중에 End가 오면 같은 객체의 EndTs/EndIdx만 갱신됨.
                if (!added.Contains(cur))
                {
                    result.Add(cur);
                    added.Add(cur);
                }
            }
            else
            {
                // Start 없이 Success만 있는 경우도 실제 로그이므로 표시
                var row = new CombinedRow
                {
                    Var = r.Var,
                    StartTs = r.Timestamp,
                    SuccessTs = r.Timestamp,
                    EndTs = r.Timestamp,
                    Status = "Success",
                    SourceFile = r.SourceFile,
                    StartIdx = (int)r.LineIndex,
                    EndIdx = (int)r.LineIndex,
                    SuccessIdx = (int)r.LineIndex,
                    DurationSeconds = 0,
                    MLot = ""
                };

                FillLotByIndex(row);
                result.Add(row);
                added.Add(row);
            }
        }
        else if (r.Kind == ActionKind.End)
        {
            if (q.Count > 0)
            {
                var cur = q.Peek();

                cur.EndTs = r.Timestamp;
                cur.EndIdx = (int)r.LineIndex;
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

                if (cur.Status == "Success")
                {
                    // Success가 이미 있던 건은 End에서 FIFO 종료만 처리
                    q.Dequeue();

                    // SuccessIdx는 Success 라인 유지
                    FillLotByIndex(cur);

                    if (!added.Contains(cur))
                    {
                        result.Add(cur);
                        added.Add(cur);
                    }
                }
                else
                {
                    // Start + End만 있는 경우는 Unknown으로 표시
                    q.Dequeue();

                    cur.Status = "Unknown";
                    cur.SuccessTs = r.Timestamp;
                    cur.SuccessIdx = (int)r.LineIndex; // Unknown의 JSON/LOT 기준은 End 라인
                    FillLotByIndex(cur);

                    if (!added.Contains(cur))
                    {
                        result.Add(cur);
                        added.Add(cur);
                    }
                }
            }
            else
            {
                // End 단독도 실제 로그이므로 Unknown 표시
                var row = new CombinedRow
                {
                    Var = r.Var,
                    StartTs = r.Timestamp,
                    SuccessTs = r.Timestamp,
                    EndTs = r.Timestamp,
                    Status = "Unknown",
                    SourceFile = r.SourceFile,
                    StartIdx = (int)r.LineIndex,
                    EndIdx = (int)r.LineIndex,
                    SuccessIdx = (int)r.LineIndex,
                    DurationSeconds = 0,
                    MLot = ""
                };

                FillLotByIndex(row);
                result.Add(row);
                added.Add(row);
            }
        }
        else if (r.Kind == ActionKind.Fail)
        {
            if (q.Count > 0)
            {
                var cur = q.Dequeue();

                cur.SuccessTs = r.Timestamp;
                cur.SuccessIdx = (int)r.LineIndex; // NG의 JSON/LOT 기준은 Fail 라인
                cur.EndTs = r.Timestamp;
                cur.EndIdx = (int)r.LineIndex;
                cur.Status = "NG";
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

                FillLotByIndex(cur);

                if (!added.Contains(cur))
                {
                    result.Add(cur);
                    added.Add(cur);
                }
            }
            else
            {
                // Fail 단독도 실제 로그이므로 NG 표시
                var row = new CombinedRow
                {
                    Var = r.Var,
                    StartTs = r.Timestamp,
                    SuccessTs = r.Timestamp,
                    EndTs = r.Timestamp,
                    Status = "NG",
                    SourceFile = r.SourceFile,
                    StartIdx = (int)r.LineIndex,
                    EndIdx = (int)r.LineIndex,
                    SuccessIdx = (int)r.LineIndex,
                    DurationSeconds = 0,
                    MLot = ""
                };

                FillLotByIndex(row);
                result.Add(row);
                added.Add(row);
            }
        }
        else
        {
            // [BR_...] 단독 로그
            if (q.Count > 0)
            {
                // 열린 Start의 상세 범위만 확장
                var cur = q.Peek();

                cur.EndTs = r.Timestamp;
                cur.EndIdx = (int)r.LineIndex;
                cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));
            }
            else
            {
                // 단독 BR 로그도 실제 로그이므로 Unknown 표시
                var row = new CombinedRow
                {
                    Var = r.Var,
                    StartTs = r.Timestamp,
                    SuccessTs = r.Timestamp,
                    EndTs = r.Timestamp,
                    Status = "Unknown",
                    SourceFile = r.SourceFile,
                    StartIdx = (int)r.LineIndex,
                    EndIdx = (int)r.LineIndex,
                    SuccessIdx = (int)r.LineIndex,
                    DurationSeconds = 0,
                    MLot = ""
                };

                FillLotByIndex(row);
                result.Add(row);
                added.Add(row);
            }
        }
    }

    // 남은 Start 처리
    foreach (var kv in queues)
    {
        var q = kv.Value;

        while (q.Count > 0)
        {
            var cur = q.Dequeue();

            if (!cur.EndTs.HasValue)
            {
                cur.EndTs = cur.SuccessTs ?? cur.StartTs;
                cur.EndIdx = cur.SuccessIdx >= 0 ? cur.SuccessIdx : cur.StartIdx;
            }

            cur.DurationSeconds = Math.Max(0, Math.Round((cur.EndTs.Value - cur.StartTs).TotalSeconds, 3));

            if (cur.Status == "Success")
            {
                // Start + Success만 있고 End가 없어도 Success 유지
                if (cur.SuccessIdx < 0)
                    cur.SuccessIdx = cur.EndIdx >= 0 ? cur.EndIdx : cur.StartIdx;

                FillLotByIndex(cur);
            }
            else
            {
                // Start만 남은 건은 Unknown
                cur.Status = "Unknown";
                cur.SuccessTs = cur.EndTs;
                cur.SuccessIdx = cur.EndIdx >= 0 ? cur.EndIdx : cur.StartIdx;

                FillLotByIndex(cur);
            }

            if (!added.Contains(cur))
            {
                result.Add(cur);
                added.Add(cur);
            }
        }
    }

    return result.OrderBy(x => x.StartTs).ThenBy(x => x.StartIdx).ToList();
}



FillLotByIndex() 없으면 이거만 추가하세요.


private void FillLotByIndex(CombinedRow row)
{
    if (row == null)
        return;

    if (!string.IsNullOrEmpty(row.MLot))
        return;

    if (row.SuccessIdx < 0)
        return;

    if (kvIndexByFile.TryGetValue(row.SourceFile, out var fileMap) &&
        fileMap.TryGetValue(row.SuccessIdx, out var pairs))
    {
        row.MLot = PickLotFromPairs(row.Var, pairs);
    }
}



핵심 변경점은 이겁니다.


Success에서 result.Add 한다.
End가 없어도 Success를 유지한다.
End가 오면 같은 객체를 업데이트만 한다.
FIFO 큐는 End/Fail에서만 Dequeue 한다.
중복 제거는 하지 않는다.



이제 Start → Success만 있어도 Success가 사라지지 않습니다.

