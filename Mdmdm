3) TreeView 선택 시 Add 버튼 활성화 로직


TreeView_AfterSelect 끝부분에 호출만 추가:


private void TreeView_AfterSelect(object? sender, TreeViewEventArgs e)
{
    // ... 기존: token을 그리드로 보여주는 코드 ...

    UpdateAddButtonState(e.Node);
}



그리고 아래 함수 추가:


private void UpdateAddButtonState(TreeNode? node)
{
    selectedArrayForAdd = null;
    selectedAddTemplate = AddTemplateType.None;
    buttonAdd.Enabled = false;

    if (node?.Tag is not JToken token)
        return;

    if (token is not JArray arr)
        return;

    // 어떤 템플릿을 적용할지 결정
    var tpl = ResolveAddTemplate(arr);
    if (tpl == AddTemplateType.None)
        return;

    selectedArrayForAdd = arr;
    selectedAddTemplate = tpl;
    buttonAdd.Enabled = true;
}

private AddTemplateType ResolveAddTemplate(JArray arr)
{
    // JArray.Path 예: "devices" / "devices[0].info"
    var path = arr.Path ?? string.Empty;

    // 루트 배열이면 Path가 ""일 수 있음
    if (string.IsNullOrWhiteSpace(path))
        return AddTemplateType.DefaultKeyValue;

    // 특정 배열이면 Ip 템플릿
    if (ArraysUsingIpTemplate.Contains(path))
        return AddTemplateType.IpIdInfoPasswordNote;

    // 그 외 배열은 기본 Key/Value 템플릿 허용(원하면 None으로 막을 수 있음)
    return AddTemplateType.DefaultKeyValue;
}




4) Add 버튼 클릭 시 실제 배열에 항목 추가


private void ButtonAdd_Click(object? sender, EventArgs e)
{
    if (selectedArrayForAdd == null)
        return;

    JObject newItem = selectedAddTemplate switch
    {
        AddTemplateType.IpIdInfoPasswordNote => CreateIpIdInfoPasswordNoteTemplate(),
        AddTemplateType.DefaultKeyValue => CreateDefaultKeyValueTemplate(),
        _ => CreateDefaultKeyValueTemplate()
    };

    selectedArrayForAdd.Add(newItem);

    // 트리/그리드 갱신(가볍게)
    // 이미 있는 함수가 있다면 그걸 쓰면 됨:
    RebuildTreeAndReselect(selectedArrayForAdd);
}

private JObject CreateDefaultKeyValueTemplate()
{
    return new JObject
    {
        ["Key"] = "",
        ["Value"] = ""
    };
}

private JObject CreateIpIdInfoPasswordNoteTemplate()
{
    return new JObject
    {
        ["Ip"] = "",
        ["Id"] = "",
        ["Info"] = new JArray { "", "" },
        ["Password"] = "",
        ["Note"] = ""
    };
}




5) “devices.info 로 넣으면 되냐”에 대한 결론 적용




devices 배열에 템플릿 적용하려면 ArraysUsingIpTemplate에 "devices" 넣으면 됩니다.


devices[0].info 같은 내부 배열에 템플릿을 적용하려면 "devices[0].info"는 인덱스가 바뀌므로 보통 EndsWith(".info") 같은 규칙을 추가합니다.




원하면 아래처럼 확장:


if (path.EndsWith(".info", StringComparison.OrdinalIgnoreCase))
    return AddTemplateType.DefaultKeyValue; // 또는 info 전용 템플릿




최소 수정으로 끝내는 방법


당장 목적이 “devices 배열만 Ip/Id/Info/Password/Note로 추가”라면




ArraysUsingIpTemplate에 "devices"만 넣고


위 코드 그대로 붙여넣으면 됩니다.




추가로 “어떤 배열은 Key/Value조차 추가 못하게” 하려면 ResolveAddTemplate에서 DefaultKeyValue 대신 None을 반환하도록 제한하면 됩니다.

