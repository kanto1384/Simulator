아래처럼 BuildKVIndexForFile() 메서드 전체 교체하세요.

핵심은 File.ReadAllLines() 제거하고 FileShare.ReadWrite | FileShare.Delete로 여는 겁니다.


private void BuildKVIndexForFile(string file)
{
    string source = Path.GetFileName(file);

    if (!kvIndexByFile.ContainsKey(source))
        kvIndexByFile[source] = new Dictionary<int, Dictionary<string, Dictionary<int, string>>>();

    if (!lotIndexByFile.ContainsKey(source))
        lotIndexByFile[source] = new Dictionary<int, string>();

    var fileMap = kvIndexByFile[source];
    var lotMap = lotIndexByFile[source];

    string[] lines;

    // 운영 로그 파일이 다른 프로세스에서 쓰는 중이어도 읽을 수 있게 처리
    using (var fs = new FileStream(
        file,
        FileMode.Open,
        FileAccess.Read,
        FileShare.ReadWrite | FileShare.Delete))
    using (var sr = new StreamReader(fs, Encoding.UTF8, true))
    {
        var list = new List<string>();

        string line;
        while ((line = sr.ReadLine()) != null)
        {
            list.Add(line);
        }

        lines = list.ToArray();
    }

    for (int i = 0; i < lines.Length; i++)
    {
        string line = lines[i];

        var hm = headRx.Match(line);
        if (!hm.Success)
            continue;

        string rest = hm.Groups["rest"].Value;

        string varName = GetVarFromHeader(source, rest);

        if (string.IsNullOrWhiteSpace(varName) ||
            !varName.StartsWith("BR_", StringComparison.OrdinalIgnoreCase))
        {
            continue;
        }

        var pairs = new Dictionary<string, Dictionary<int, string>>(StringComparer.OrdinalIgnoreCase);

        int j = i + 1;

        while (j < lines.Length)
        {
            string bodyLine = lines[j];

            // 다음 로그 헤더가 나오면 현재 블록 종료
            if (headRx.IsMatch(bodyLine))
                break;

            var kv = Regex.Match(
                bodyLine,
                @"^\s*\[(?<idx>\d+)\s*:\s*(?<key>[^\]]+)\]\s*:\s*(?<val>.*)$",
                RegexOptions.IgnoreCase);

            if (kv.Success)
            {
                int idx;
                if (!int.TryParse(kv.Groups["idx"].Value, out idx))
                    idx = 0;

                string key = kv.Groups["key"].Value.Trim();
                string val = kv.Groups["val"].Value.Trim();

                if (!pairs.TryGetValue(key, out var byIndex))
                {
                    byIndex = new Dictionary<int, string>();
                    pairs[key] = byIndex;
                }

                byIndex[idx] = val;
            }

            j++;
        }

        if (pairs.Count > 0)
        {
            fileMap[i] = pairs;

            string lot = PickLotFromPairs(varName, pairs);
            if (!string.IsNullOrWhiteSpace(lot))
                lotMap[i] = lot;
        }
    }
}



이 메서드로 바꾸면 해당 에러는 잡힙니다.


The process cannot access the file because it is being used by another process.



원인은 File.ReadAllLines()가 아니라, 운영 로그 파일을 다른 프로세스가 쓰는 중인데 공유 옵션 없이 읽으려고 해서 발생한 겁니다.

